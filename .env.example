# Supabase (Portal auth + RLS + Vault)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Service-role key: server-only. Used to read decrypted Vault secrets and for admin tasks.
# NEVER expose to the browser or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic — Taptico's fallback key (used when an org has uses_taptico_key = true)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (transactional email — admin notifications, welcome, etc.)
RESEND_API_KEY=re_...
RESEND_FROM="TapticoAI <notifications@app.taptico.ai>"
ADMIN_EMAIL=admin@taptico.ai

# Community
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite

# Go High Level (legacy waitlist lead capture — optional)
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=Cvc5EmclHsFLw9BIuthx
